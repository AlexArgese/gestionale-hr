# Server
NODE_ENV=production
PORT=3001
TZ=Europe/Rome

# Database (PROD userà una stringa unica)
DATABASE_URL=

# Whistleblowing / crypto
WB_AES_KEY=
WB_POLICY_VERSION=2025-08-24
WB_NOTIFY_TO=
WB_MAIL_REPLY_TO=no-reply@clockeasy.local
