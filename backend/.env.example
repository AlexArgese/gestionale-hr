# Antivirus (in prod NON usiamo path locali mac)
WB_AV_MODE=off
CLAMSCAN_BIN=
WB_AV_DEBUG=0

# Yousign
YOUSIGN_API_KEY=
YOUSIGN_BASE_URL=https://api.yousign.app/v3
